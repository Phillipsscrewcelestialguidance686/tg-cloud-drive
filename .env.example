# TG Cloud Drive - Environment Configuration
# Copy this file to '.env.local' and supply your credentials.

# 1. Decentralized Sync Database (ClashDB or KV store)
# This database coordinates file indexing metadata across multiple authenticated Telegram accounts/sessions.
VITE_CLASHDB_URL=https://your-clashdb-instance.vercel.app
VITE_CLASHDB_PASSWORD=your_secure_db_password
